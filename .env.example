# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — resend.com → API Keys
RESEND_API_KEY=
BOOKING_FROM_EMAIL=
BOOKING_ADMIN_EMAIL=

# Base URL for canonical SEO, sitemap, OG and email links.
# Production: https://www.movingpace.nl  ·  Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails allowed to access /admin
ADMIN_EMAILS=
